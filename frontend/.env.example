# Browser API calls: default is same-origin `/api` + `/sanctum` (see
# `next.config.mjs` rewrites). Do NOT set NEXT_PUBLIC_API_URL to the Laravel
# host:port unless you know you need cross-origin + token auth — it breaks
# Sanctum cookie CSRF (419). To force a direct API base in the browser, set
# both of the following:
#   NEXT_PUBLIC_API_DIRECT=true
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_DIRECT=false
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_HOST_IP=127.0.0.1

# Server-side only — rewrite + SSR target for Laravel. Docker Compose sets
# http://backend:8000. On the host: http://127.0.0.1:<your-api-port>
INTERNAL_API_URL=http://127.0.0.1:8000
