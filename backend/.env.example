APP_NAME="AAOP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Frontend (Fusion-MCP themed Next.js app)
FRONTEND_URL=http://127.0.0.1:3000

# ---------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------
# Database — MySQL 8.4 (docker service `mysql`)
# ---------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=aaop
DB_USERNAME=aaop
DB_PASSWORD=aaopsecret

# ---------------------------------------------------------------------
# Cache / Queue / Sessions / Broadcasting — Redis (docker service `redis`)
# ---------------------------------------------------------------------
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
# Leave empty for host-only session cookies (recommended for Next.js same-origin dev).
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------
# Mail — Mailpit (docker service `mailpit`)
# ---------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@aaop.local"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------
# Sanctum / SPA auth (cookie-based for the Next.js frontend)
# ---------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:3000,localhost:3000
SANCTUM_TOKEN_PREFIX=aaop_

# ---------------------------------------------------------------------
# AAOP — platform-specific knobs
# ---------------------------------------------------------------------
AAOP_TENANT_DEFAULT_REGION=us-ashburn-1
AAOP_AUDIT_HASH_SECRET=change-me-in-production
AAOP_RUN_DEFAULT_TIMEOUT=600

# Phase 2 — optional MCP HTTP bridge (see `McpGatewayService`)
AAOP_MCP_REMOTE_BASE=

# CUA / trycua (0 = stub responses in dev)
CUA_ENABLED=0
CUA_SANDBOX_IMAGE=linux-chrome:latest
