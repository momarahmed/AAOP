# =====================================================================
# AAOP — root .env.example (used by docker-compose)
# Copy to .env at the repository root before `docker compose up -d`.
# =====================================================================

# ---------------------------------------------------------------------
# Container UIDs (match host user to avoid file-permission pain)
#   Linux/macOS:  echo "UID=$(id -u)" >> .env && echo "GID=$(id -g)" >> .env
# ---------------------------------------------------------------------
UID=1000
GID=1000

# ---------------------------------------------------------------------
# Host port bindings (change if a port is in use on your machine)
# ---------------------------------------------------------------------
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8000
DB_HOST_PORT=3306
REDIS_HOST_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ---------------------------------------------------------------------
# MySQL credentials (used by both `mysql` and `backend` services)
# ---------------------------------------------------------------------
DB_DATABASE=aaop
DB_USERNAME=aaop
DB_PASSWORD=aaopsecret
DB_ROOT_PASSWORD=rootsecret

# ---------------------------------------------------------------------
# Federated SSO (Phase 4-5). Leave empty / disabled if you don't use SSO.
# Each provider needs ENABLED=true plus a valid client id/secret.
# Redirect URI on the IdP side must be:
#   <FRONTEND_URL>/login/sso/callback
# ---------------------------------------------------------------------
SSO_GOOGLE_ENABLED=false
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=

SSO_MICROSOFT_ENABLED=false
SSO_MICROSOFT_CLIENT_ID=
SSO_MICROSOFT_CLIENT_SECRET=
SSO_MICROSOFT_TENANT=common

SSO_OKTA_ENABLED=false
SSO_OKTA_CLIENT_ID=
SSO_OKTA_CLIENT_SECRET=
SSO_OKTA_DOMAIN=

# ---------------------------------------------------------------------
# WebAuthn / FIDO2 — relying party config for passkeys.
# `WEBAUTHN_RP_ID` MUST match the SPA host (effective domain).
# ---------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=AAOP
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_TIMEOUT_MS=60000
